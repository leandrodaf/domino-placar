<?xml version="1.0" encoding="utf-8"?>
<!-- Tema noturno — idêntico ao padrão (app é 100% dark) -->
<resources>
    <style name="Theme.DominoPlacar" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:colorPrimary">@color/accent</item>
        <item name="android:colorPrimaryDark">@color/bg</item>
        <item name="android:colorAccent">@color/accent</item>
    </style>

    <style name="Theme.DominoPlacar.Splash" parent="Theme.DominoPlacar">
        <item name="android:windowBackground">@color/bg</item>
    </style>
</resources>
