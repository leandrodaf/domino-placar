# Porta do servidor (padrão: 8080)
PORT=8080

# Hostname usado nos QR codes e links de convite
# Em produção, use o IP local ou domínio público
HOST=localhost

# ─── Firebase Realtime Database ───────────────────────────────────────────────
# Se definido, o app usa Firebase em vez do SQLite local.

# URL do banco de dados Firebase
# Exemplo: https://meu-projeto-default-rtdb.firebaseio.com
FIREBASE_DATABASE_URL=

# Credenciais da conta de serviço Firebase (conteúdo JSON em linha única)
# Alternativa: configure GOOGLE_APPLICATION_CREDENTIALS apontando para o arquivo JSON
# Se vazio, usa Application Default Credentials (útil em Cloud Run / GCP)
FIREBASE_CREDENTIALS=

# ─── SQLite (fallback quando FIREBASE_DATABASE_URL não está definido) ─────────
# Nenhuma configuração necessária. O arquivo domino.db é criado automaticamente.

# ─── IA de análise de fotos (opcional) ────────────────────────────────────────
# Sem estas variáveis, apenas a entrada manual de pontos funciona.
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL=domino-detection
ROBOFLOW_VERSION=1
